rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Total Admin Access for the primary user
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'SafiraRahmadini8@gmail.com';
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Default Allow Read for all signed in users for these specific collections
    // to ensure dashboard/reports work even if not the primary user
    match /skpds/{skpdId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /anggarans/{anggaranId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /realisasis/{realisasiId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
